<UserControl x:Class="SolidWorks.ParametricAddin.TaskPane.DesignModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:SolidWorks.ParametricAddin.TaskPane.ViewModels"
             xmlns:helpers="clr-namespace:SolidWorks.ParametricAddin.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="300">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#424242" />
            <Setter Property="Margin" Value="0,4,0,2" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Background" Value="#1976d2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Background" Value="#e0e0e0" />
            <Setter Property="Foreground" Value="#37474f" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,12">
            <!-- Back button -->
            <Button Content="返回"
                    Command="{Binding DataContext.SwitchToSelectModeCommand, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Left" Width="60" Margin="0,0,0,8" />

            <TextBlock Text="设计模式" FontSize="15" FontWeight="SemiBold" Foreground="#1a237e" Margin="0,0,0,10" />

            <!-- Basic Settings -->
            <Expander Header="基本设置" IsExpanded="True" Margin="0,0,0,4">
                <StackPanel Margin="0,4,0,0">
                    <TextBlock Text="模板名称" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}" />

                    <TextBlock Text="输出目录" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}" />

                    <TextBlock Text="命名模板" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding NamingPattern, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}"
                             ToolTip="使用 {参数名} 引用参数值。例如: 传送带_L{Length}_W{Width}" />

                    <TextBlock Text="备注" Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}" Height="50" TextWrapping="Wrap"
                             AcceptsReturn="True" />
                </StackPanel>
            </Expander>

            <!-- Parameters -->
            <Expander Header="参数列表" IsExpanded="True" Margin="0,4,0,4">
                <StackPanel Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="从 SW 读取" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ReadEquationsCommand}" ToolTip="从当前模型读取所有方程式/全局变量"
                                Width="100" />
                        <Button Content="手动添加" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AddParameterCommand}" Width="80" Margin="4,3,0,3" />
                        <Button Content="删除" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RemoveParameterCommand}" Width="50" Margin="4,3,0,3" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Parameters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#e0e0e0" BorderThickness="0,0,0,1" Padding="4,4,4,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding EquationName}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   ToolTip="方程式变量名" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                   FontSize="11" Foreground="#616161"
                                                   ToolTip="显示标签" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding ControlType}"
                                                   FontSize="10" Foreground="#9e9e9e"
                                                   VerticalAlignment="Center" Margin="4,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

            <!-- Rules -->
            <Expander Header="规则编辑器" IsExpanded="True" Margin="0,4,0,4">
                <StackPanel Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="添加规则" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AddRuleCommand}" Width="80" />
                        <Button Content="删除" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RemoveRuleCommand}" Width="50" Margin="4,0,0,0" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Rules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#bbdefb" BorderThickness="1" CornerRadius="4"
                                        Background="#e3f2fd" Padding="6" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   FontSize="12" Foreground="#1565c0" Margin="0,0,0,4" />

                                        <TextBlock FontSize="10" Foreground="#546e7a">
                                            <Run Text="IF 条件数: " />
                                            <Run Text="{Binding Conditions.Count}" />
                                        </TextBlock>

                                        <TextBlock FontSize="10" Foreground="#546e7a">
                                            <Run Text="THEN 动作数: " />
                                            <Run Text="{Binding ThenActions.Count}" />
                                        </TextBlock>

                                        <TextBlock FontSize="10" Foreground="#546e7a">
                                            <Run Text="ELSE 动作数: " />
                                            <Run Text="{Binding ElseActions.Count}" />
                                        </TextBlock>

                                        <CheckBox Content="启用" IsChecked="{Binding Enabled}"
                                                  FontSize="11" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

            <!-- Actions -->
            <Border BorderBrush="#e0e0e0" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,8,0,0">
                <StackPanel>
                    <Button Content="保存模板" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SaveTemplateCommand}" />
                    <Button Content="清空所有" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ClearAllCommand}" />
                </StackPanel>
            </Border>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#757575"
                       TextWrapping="Wrap" Margin="0,8,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
